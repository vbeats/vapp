{
	"easycom": {
		"^u-(.*)": "@/uview-ui/components/u-$1/u-$1.vue"
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/index/index",
			"style": {
				"enablePullDownRefresh": false
			}
		}, {
			"path": "pages/group/group",
			"style": {
				"enablePullDownRefresh": false
			}
		}, {
			"path": "pages/shop/shop",
			"style": {
				"enablePullDownRefresh": false
			}

		}, {
			"path": "pages/message/message",
			"style": {
				"enablePullDownRefresh": false
			}

		}, {
			"path": "pages/me/me",
			"style": {
				"enablePullDownRefresh": false
			}

		}
	],
	"globalStyle": {
		"navigationStyle": "custom",
		"navigationBarTextStyle": "white"
	},
	"tabBar": {
		"position": "bottom",
		"borderStyle": "white",
		"list": [{
				"pagePath": "pages/index/index",
				"text": "",
				"iconPath": "static/images/index.png",
				"selectedIconPath": "static/images/index_s.png"
			},
			{
				"pagePath": "pages/group/group",
				"text": "",
				"iconPath": "static/images/group.png",
				"selectedIconPath": "static/images/group_s.png"
			},
			{
				"pagePath": "pages/shop/shop",
				"text": "",
				"iconPath": "static/images/shop.png",
				"selectedIconPath": "static/images/shop_s.png"
			},
			{
				"pagePath": "pages/message/message",
				"text": "",
				"iconPath": "static/images/message.png",
				"selectedIconPath": "static/images/message_s.png"
			},
			{
				"pagePath": "pages/me/me",
				"text": "",
				"iconPath": "static/images/me.png",
				"selectedIconPath": "static/images/me_s.png"
			}
		]
	},
	"subPackages": [{
		"root": "pages/sub",
		"pages": [{
			"path": "login/login",
			"style": {
				"enablePullDownRefresh": false
			}
		}]
	}]
